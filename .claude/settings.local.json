{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "Skill(mempalace:init)",
      "PowerShell(New-Item *)",
      "PowerShell(Copy-Item *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "code-review-graph"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/update_project_structure.py"
          }
        ]
      }
    ]
  }
}
